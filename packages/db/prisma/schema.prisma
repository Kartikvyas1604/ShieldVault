generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  wallet_address String   @id
  created_at     DateTime @default(now())
  last_seen      DateTime @updatedAt

  vaultPositions   VaultPosition[]
  protectionRules  ProtectionRule[]
  hedgePositions   HedgePosition[]
}

model VaultPosition {
  id             String   @id @default(cuid())
  wallet_address String
  sol_amount     BigInt
  shares         BigInt
  deposited_at   DateTime @default(now())
  status         String   // ACTIVE/WITHDRAWN

  user           User     @relation(fields: [wallet_address], references: [wallet_address])
}

model ProtectionRule {
  id               String   @id @default(cuid())
  wallet_address   String
  encrypted_rule   String
  rule_hash        String   @unique
  trigger_percent  Float
  hedge_percent    Float
  timeout_minutes  Int
  status           String   // ACTIVE/INACTIVE/TRIGGERED
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user             User            @relation(fields: [wallet_address], references: [wallet_address])
  hedgePositions   HedgePosition[]
}

model HedgePosition {
  id                 String   @id @default(cuid())
  rule_id            String
  wallet_address     String
  drift_position_id  String?
  entry_price        Float
  short_size_sol     Float
  entry_timestamp    DateTime @default(now())
  close_timestamp    DateTime?
  close_reason       String?  // RECOVERY/TIMEOUT/WITHDRAWAL/MANUAL
  funding_paid_total Float    @default(0)
  realized_pnl       Float?
  status             String   // OPEN/CLOSED/FAILED

  rule               ProtectionRule      @relation(fields: [rule_id], references: [id])
  user               User                @relation(fields: [wallet_address], references: [wallet_address])
  operatorApprovals  OperatorApproval[]
  proofBundles       ProofBundle[]
}

model OperatorApproval {
  id                 String   @id @default(cuid())
  hedge_position_id  String
  operator_index     Int
  signature          String
  approved_at        DateTime @default(now())
  price_at_approval  Float

  hedgePosition      HedgePosition @relation(fields: [hedge_position_id], references: [id])
}

model ProofBundle {
  id                  String   @id @default(cuid())
  hedge_position_id   String
  rule_hash           String
  price_snapshot      Json
  execution_timestamp DateTime
  operator_signatures Json
  proof_data          Json
  created_at          DateTime @default(now())

  hedgePosition       HedgePosition @relation(fields: [hedge_position_id], references: [id])
}

model PriceSnapshot {
  id                 String   @id @default(cuid())
  pyth_price         Float
  jupiter_price      Float
  consensus_price    Float
  deviation_percent  Float
  is_valid           Boolean
  captured_at        DateTime @default(now())
}

model AuditLog {
  id             String   @id @default(cuid())
  wallet_address String
  action         String
  metadata       Json
  timestamp      DateTime @default(now())
}
